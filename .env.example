# Copy to .env for docker compose. Compose substitutes these into the services.

# --- secrets ---
OPENAI_API_KEY=replace_me
JWT_SECRET=change-me-to-a-long-random-string

# --- optional model controls (consumed by the Go backend) ---
OPENAI_PLAN_MODEL=gpt-4.1
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_QUALITY=medium

# --- frontend → backend wiring ---
# Base URL the browser uses to reach the Go API.
PUBLIC_API_BASE=http://localhost:8080
# Allowed CORS origins for the API (comma-separated).
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
